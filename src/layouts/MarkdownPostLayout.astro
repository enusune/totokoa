---
import BaseLayout from "./BaseLayout.astro";
const { frontmatter } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const publishedTime = frontmatter.pubDate
  ? new Date(frontmatter.pubDate).toISOString()
  : undefined;
const articleStructuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  mainEntityOfPage: canonicalURL.href,
  headline: frontmatter.title,
  description: frontmatter.description,
  datePublished: publishedTime,
  author: {
    "@type": "Person",
    name: frontmatter.author,
  },
  keywords: frontmatter.keywords,
  articleSection: frontmatter.tags,
  image: frontmatter.image?.url ? [frontmatter.image.url] : undefined,
};
---

<BaseLayout
  pageTitle={frontmatter.title}
  description={frontmatter.description}
  image={frontmatter.image}
  author={frontmatter.author}
  pubDate={publishedTime}
  keywords={frontmatter.keywords}
  structuredData={articleStructuredData}
  type="article"
>
  <article class="post-shell">
    <header class="post-header">
      <h1>{frontmatter.title}</h1>
      <div class="post-meta">
        <span>{frontmatter.author}</span>
        {publishedTime && (
          <>
            <span aria-hidden="true">·</span>
            <time datetime={publishedTime}>
              {new Date(frontmatter.pubDate).toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </time>
          </>
        )}
      </div>
    </header>
  <div class="post-content">
    <slot />
  </div>
  {
    frontmatter.tags && frontmatter.tags.length > 0 && (
      <nav class="tags" aria-label="Post topics">
        {frontmatter.tags.map((tag: string) => (
          <a href={`/tags/${tag}`} class="tag">
            {tag}
          </a>
        ))}
      </nav>
    )
  }
  </article>
</BaseLayout>

<style>
  .post-shell {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .post-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .post-content {
    max-width: 60ch;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    padding-top: var(--space-4);
    border-top: 1px dashed var(--color-border);
  }

  .tag {
    display: inline-block;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    color: var(--color-text);
    border: 1px dashed var(--color-border);
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: var(--space-1) var(--space-3);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition:
      background-color 0.15s ease,
      color 0.15s ease,
      border-color 0.15s ease;
  }

  .tag:hover {
    background-color: var(--color-surface-elevated);
    color: var(--color-text);
    border-color: var(--color-border-strong);
  }
</style>
