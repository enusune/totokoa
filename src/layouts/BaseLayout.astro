---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  pageTitle: string;
  description?: string;
  image?: { url: string; alt: string };
  author?: string;
  pubDate?: string;
  keywords?: string[];
  robots?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  type?: "website" | "article";
}

const {
  pageTitle,
  description = "AI Tools, Full-Stack Development, and Efficiency Improvement",
  image,
  author = "Enusune",
  pubDate,
  keywords = [],
  robots = "index,follow,max-image-preview:large",
  structuredData = [],
  type = "website",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = image?.url ?? new URL("/favicon.svg", Astro.site).href;
const siteName = "Bloooooooooog";
const normalizedStructuredData = Array.isArray(structuredData)
  ? structuredData
  : [structuredData];
const baseSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  headline: pageTitle,
  description,
  url: canonicalURL.href,
  image: [ogImage],
  author: {
    "@type": "Person",
    name: author,
  },
  datePublished: pubDate,
  isPartOf: {
    "@type": "WebSite",
    name: siteName,
    url: Astro.site?.href,
  },
};
const combinedStructuredData = [baseSchema, ...normalizedStructuredData].filter(
  (item) => Object.keys(item).length > 0,
);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />

    <title>{pageTitle} | {siteName}</title>
    <meta name="description" content={description} />
    {author && <meta name="author" content={author} />}
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(", ")} />}
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#111111" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    {image?.alt && <meta property="og:image:alt" content={image.alt} />}
    {pubDate && <meta property="article:published_time" content={pubDate} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {image?.alt && <meta name="twitter:image:alt" content={image.alt} />}
    <meta name="twitter:url" content={canonicalURL} />

    <!-- RSS -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={siteName}
      href="/rss.xml"
    />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(combinedStructuredData)}
    />

    <script is:inline>
      const stored = localStorage?.getItem("theme");
      const prefersDark = window.matchMedia(
        "(prefers-color-scheme: dark)",
      ).matches;
      if (stored === "dark" || (!stored && prefersDark)) {
        document.documentElement.classList.add("dark");
      }
    </script>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-40NREQMY76"
    ></script>
    <script>
      // @ts-ignore
      window.dataLayer = window.dataLayer || [];
      // @ts-ignore
      function gtag() {
        // @ts-ignore
        dataLayer.push(arguments);
      }
      // @ts-ignore
      gtag("js", new Date());
      // @ts-ignore
      gtag("config", "G-40NREQMY76");
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header />
    <main class="page-shell">
      <slot />
    </main>
    <Footer />
    <script>
      import "../scripts/menu.js";
    </script>
  </body>
</html>
<style>
  .page-shell {
    max-width: var(--max-width);
    padding: var(--space-6) var(--page-gutter) calc(var(--footer-height) + var(--space-4));
    margin: 0 auto;
  }

  @media screen and (min-width: 636px) {
    .page-shell {
      padding-top: var(--space-8);
    }
  }
</style>
