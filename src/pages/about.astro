---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "About";
const description =
  "About Enusune, a full-stack developer writing about AI tooling and practical software delivery.";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: "About Enusune",
  description,
};
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  structuredData={structuredData}
>
  <section class="page-stack">
    <header class="page-header">
      <span class="page-eyebrow">About</span>
      <!-- <h1 class="page-title">About Enusune</h1>
      <p class="page-description">
        Full-stack engineering, AI tooling, and the execution discipline behind
        shipping useful software.
      </p> -->
    </header>

    <div class="page-body">
      <p>
        I'm a full-stack developer focused on building reliable web products
        across backend systems and modern frontend interfaces.
      </p>

      <p>
        This blog is where I collect notes on AI tooling, coding workflows, and
        the practical tradeoffs behind shipping software with less friction.
      </p>

      <p>
        Most of the writing here sits at the intersection of engineering,
        tooling, and day-to-day execution quality.
      </p>
    </div>
  </section>
</BaseLayout>
