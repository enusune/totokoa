---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "About";
---

<BaseLayout pageTitle={pageTitle}>
  <section class="page-stack">
    <header class="page-header">
      <span class="page-eyebrow">About</span>
    </header>

    <div class="page-body">
      <p>
        I'm a full-stack developer focused on building reliable web products
        across backend systems and modern frontend interfaces.
      </p>

      <p>
        This blog is where I collect notes on AI tooling, coding workflows, and
        the practical tradeoffs behind shipping software with less friction.
      </p>

      <p>
        Most of the writing here sits at the intersection of engineering,
        tooling, and day-to-day execution quality.
      </p>
    </div>
  </section>
</BaseLayout>
