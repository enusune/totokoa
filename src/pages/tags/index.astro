---
import BaseLayout from "../../layouts/BaseLayout.astro";
const pageTitle = "Tags";
const description =
  "Browse blog topics by tag, including AI tools, workflows, and software delivery themes.";
const allPosts = Object.values(
  import.meta.glob("../posts/*.md", { eager: true }),
);
const tags = [
  ...new Set(allPosts.map((post: any) => post.frontmatter.tags).flat()),
];
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Blog tags",
  description,
};
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  structuredData={structuredData}
>
  <section class="page-stack">
    <header class="page-header">
      <span class="page-eyebrow">Topics</span>
      <!-- <h1 class="page-title">Browse by topic</h1>
      <p class="page-description">
        Tag hubs that group related posts for search engines and readers.
      </p> -->
    </header>

    <ul class="plain-list tag-grid">
      {
        tags.map((tag) => (
          <li>
            <a href={`/tags/${tag}`} class="tag-link">{tag}</a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
