---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogPost from "../../components/BlogPost.astro";

export async function getStaticPaths() {
  const allPosts = Object.values(
    import.meta.glob("../posts/*.md", { eager: true }) as Record<string, any>,
  );

  const uniqueTags = [
    ...new Set(allPosts.flatMap((post) => post.frontmatter.tags ?? [])),
  ];

  return uniqueTags.map((tag) => ({
    params: { tag },
    props: {
      posts: allPosts
        .filter((post) => post.frontmatter.tags?.includes(tag))
        .map((post) => ({
          url: post.url,
          title: post.frontmatter.title,
          pubDate: post.frontmatter.pubDate,
        }))
        .sort(
          (a: any, b: any) =>
            new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime(),
        ),
    },
  }));
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<BaseLayout pageTitle={tag}>
  <section class="page-stack">
    <header class="page-header">
      <span class="page-eyebrow">Tag</span>
      <h1 class="page-title">{tag}</h1>
      <p class="page-description">Posts filed under this topic.</p>
    </header>

    {
      posts?.length > 0 ? (
        <ul class="plain-list">
          {posts.map((post: any) => (
            <BlogPost url={post.url} title={post.title} pubDate={post.pubDate} />
          ))}
        </ul>
      ) : (
        <div class="page-body">
          <p>No posts found with the "{tag}" tag.</p>
        </div>
      )
    }
  </section>
</BaseLayout>
